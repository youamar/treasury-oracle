# --- Chutes API ---
CHUTES_API_KEY=your_chutes_api_key_here
CHUTES_API_KEY_FALLBACK=your_chutes_fallback_key_here
CHUTES_BASE_URL=https://llm.chutes.ai/v1

# --- Vision (OCR) ---
VISION_MODEL=google/gemma-4-31B-turbo-TEE

# --- Reasoning / agent loop ---
# Chutes pool routing: comma-separated model IDs with an optional
# `:latency` or `:throughput` suffix telling Chutes which dimension
# to optimize. The agent loop uses `:latency` (lowest TTFT — wins
# for tight 6-step tool-calling loops).
REASONING_MODEL=zai-org/GLM-5.1-TEE,Qwen/Qwen3.5-397B-A17B-TEE,MiniMaxAI/MiniMax-M2.5-TEE:latency

# Per-role model overrides (all optional — fall back to REASONING_MODEL)
CHUTES_MODEL_DEFAULT=zai-org/GLM-5.1-TEE,Qwen/Qwen3.5-397B-A17B-TEE,MiniMaxAI/MiniMax-M2.5-TEE:latency
CHUTES_MODEL_CHEAP=MiniMaxAI/MiniMax-M2.5-TEE
CHUTES_MODEL_STRONG=Qwen/Qwen3.5-397B-A17B-TEE
CHUTES_MODEL_NARRATIVE=zai-org/GLM-5.1-TEE

# --- Agent runtime knobs (optional; per-tenant DB values override these) ---
# AGENT_LLM_CONCURRENCY=4
# AGENT_MAX_STEPS=6
# AGENT_TEMPERATURE=0.0
